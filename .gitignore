# Secrets (never commit)
agents/*/.env
agents/*/workspace/.env
!agents/template/.env.example

# Per-agent runtime state (generated by compose-up.sh)
agents/*/config-runtime/
agents/*/logs/
agents/*/docker-compose.yml
# Backup archives (backup-agent.sh; may contain runtime state)
agents/*/backups/

# Per-agent runtime session/config state (container-managed, not committed)
agents/*/config/agents/main/sessions/
agents/*/config/cron/*.bak
agents/*/config/update-check.json
agents/*/config/memory/

# Config workspace is container-managed (OpenClaw writes here at runtime)
# Exception: template ships stock OpenClaw workspace files as part of the skeleton
agents/*/config/workspace/
!agents/template/config/workspace/

# Models.json is rewritten by the container at runtime with live pricing
# Exception: template ships the reference copy
agents/*/config/agents/main/agent/models.json
!agents/template/config/agents/main/agent/models.json

# Telegram offset state (container-managed)
agents/*/config/telegram/update-offset-*.json

# Workspace memory (agent-managed daily notes, not committed)
agents/*/workspace/memory/
# Per-agent runtime/personal workspace files (template + sample-agent keep placeholders only)
agents/*/workspace/onboarding-log.md
# Productwatcher runtime vault (watches, health, market data)
agents/*/workspace/skills/productwatcher/watcher_vault/

# OpenClaw workspace runtime state (onboarding timestamp, etc. — do not commit)
agents/*/workspace/.openclaw/
# Nested workspace/workspace/ — created when a skill writes paths relative to
# the workspace mount instead of .openclaw root (path bug, gitignore the artifact)
agents/*/workspace/workspace/

# User/personal content in agent workspace root (care plans, exports, etc.) — do not commit
agents/*/workspace/*.html
agents/*/workspace/*.txt
# Per-host: when present, disables PiGlow/PiFace (create on headless; leave absent on Pi with hardware)
agents/*/workspace/HARDWARE.md

# Skill runtime logs (agent-written feedback, not code)
agents/*/workspace/skills/*/logs/
# Send-email SMTP credentials (compose-up writes from agent .env into workspace for sandbox)
agents/*/workspace/skills/send-email/.env

# Ollama host scan cache (runtime artifact, changes on every scan)
agents/*/workspace/ollama-best-known.json
agents/*/workspace/skills/image-gen/ollama-hosts.json
# Ollama last-used host/model persistence (runtime)
agents/*/workspace/skills/image-gen/ollama-last.json
# PiGlow signal URL (written by compose-up.sh for pibot; host-specific)
agents/*/workspace/skills/piglow-signal/signal_url
agents/*/workspace/piglow/signal_url

# IR learner temp file (scripts/ir-learn.py)
agents/*/workspace/ir-codes/.tmp_one.ir

# Image-gen output (script writes here so send-photo exec can read; workspace shared across execs)
agents/*/workspace/skills/image-gen/generated-*.png
# PDF-reader extracted page images (GC cleans when disk < 20%; do not commit)
agents/*/workspace/skills/pdf-reader/pages/

# RFID last-scan state (host daemon writes; do not commit)
agents/*/workspace/rfid/last_scan.json
agents/*/workspace/rfid/scans.jsonl
agents/*/workspace/rfid/.last_notified.json
agents/*/workspace/rfid/.watcher_state.json
# RFID daemon log and venv (Pi host)
agents/*/workspace/rfid/daemon.log
agents/*/workspace/rfid/.venv/

# Audio bridge venv (Pi host; faster-whisper)
agents/*/workspace/audio/.venv/

# USB camera capture output (kept for debugging but not committed)
agents/*/workspace/camera/latest.jpg
agents/*/workspace/camera/capture_*.jpg
agents/*/workspace/camera/_capture_tmp.jpg
agents/*/workspace/camera/service.log

node_modules/

# Python bytecode and cache (do not commit)
*.pyc
*.pyo
__pycache__/
*.py[cod]
*$py.class
.Python
*.so

# Top-level runtime logs (LaunchAgent stdout/stderr, session-healer, etc.)
logs/
THIS_IS_*

# Local / dev (browser automation test assets, do not commit)
browser_files/

agents/*/workspace/*.png
agents/*/workspace/rfid/ding.wav
agents/*/workspace/rfid/woof.wav
agents/*/workspace/rfid/scan_sound.wav
agents/*/workspace/skills/image-vision/ollama-last.json

# Audio recordings (runtime artifacts, do not commit)
agents/*/workspace/audio/*.wav
agents/sample-agent/workspace/skills/*/ollama-hosts.json
