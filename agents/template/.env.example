# Copy to .env and set real values. Never commit .env.

# Required for gateway auth (HTTP/WS clients):
OPENCLAW_GATEWAY_TOKEN=

{{CLOUD_API_KEY_LINE}}

# Optional — Telegram bot (create via @BotFather):
TELEGRAM_BOT_TOKEN=

# Optional — web search + restaurant-scout skill (requires one of these):
#   Brave Search API: https://brave.com/search/api/ (recommended, pay-as-you-go)
# BRAVE_API_KEY=
#   Perplexity (alternative): https://docs.perplexity.ai/
# PERPLEXITY_API_KEY=
#
# To activate after adding a key:
#   1. Set tools.web.search.enabled = true in config/openclaw.json
#   2. Set skills.entries.restaurant-scout.enabled = true in config/openclaw.json
#   3. Run: ./scripts/compose-up.sh <agent-name> -d

# Optional — weather (this image's bundled weather uses wttr.in, no key needed):
# OPENWEATHERMAP_API_KEY=

# Email (SMTP via Gmail) — used for admin notifications and onboarding status
SMTP_FROM_EMAIL=
GMAIL_APP_PASSWORD=

# Optional — internal learning feedback (owner-only, never user-visible)
# Set a real recipient to receive post-run quality feedback copies:
LEARNING_FEEDBACK_EMAIL=
# immediate (default), digest, or off
LEARNING_FEEDBACK_EMAIL_MODE=immediate
# Digest controls (used when mode=digest)
LEARNING_FEEDBACK_DIGEST_MIN_RUNS=10
LEARNING_FEEDBACK_DIGEST_MINUTES=120
# Set true to disable optional LLM-as-judge calibration
LEARNING_FEEDBACK_DISABLE_LLM_JUDGE=false

# Required for OpenClaw v2026.2.21+ (gateway refuses to start without this):
OPENCLAW_OWNER_DISPLAY_SECRET=
