{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://host.docker.internal:11434/v1",
        "api": "openai-completions",
        "apiKey": "ollama",
        "models": [
          {
            "id": "qwen3:8b",
            "name": "Qwen3 8B (local)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "qwen3:14b",
            "name": "Qwen3 14B (local)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "qwen2.5-coder:14b",
            "name": "Qwen2.5 Coder 14B (local)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          },
          {
            "id": "llama3.2:latest",
            "name": "Llama 3.2 (local)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      },
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "models": [
          {
            "id": "gpt-5-mini",
            "name": "Default (GPT-5 family)",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0.25,
              "output": 2.0,
              "cacheRead": 0.025,
              "cacheWrite": 0.25
            },
            "contextWindow": 400000,
            "maxTokens": 128000
          },
          {
            "id": "gpt-5-nano",
            "name": "Nano (heartbeat/lightweight)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0.05,
              "output": 0.4,
              "cacheRead": 0.005,
              "cacheWrite": 0.05
            },
            "contextWindow": 400000,
            "maxTokens": 128000
          },
          {
            "id": "gpt-4o",
            "name": "Cloud Fallback",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 2.5,
              "output": 10,
              "cacheRead": 1.25,
              "cacheWrite": 2.5
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5-mini",
        "fallbacks": [
          "ollama/qwen3:8b"
        ]
      },
      "timeoutSeconds": 600,
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "heartbeat": {
        "every": "2h",
        "model": "openai/gpt-5-nano"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "logging": {
    "level": "debug"
  },
  "gateway": {
    "port": 18792,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18792",
        "http://127.0.0.1:18792"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "dmPolicy": "allowlist",
      "allowFrom": ["0"],
      "groupPolicy": "allowlist",
      "groupAllowFrom": ["0"],
      "groups": {
        "*": { "requireMention": true }
      },
      "streaming": "partial",
      "botToken": "not-configured"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": false
      }
    }
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw"
  },
  "skills": {
    "entries": {
      "restaurant-scout": { "enabled": false },
      "shopify-nexus": { "enabled": false },
      "fashion-radar": { "enabled": false },
      "style-profile": { "enabled": false },
      "llm-manager": { "enabled": false }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": false
      },
      "fetch": {
        "enabled": true,
        "maxChars": 100000,
        "timeoutSeconds": 45
      }
    }
  }
}
