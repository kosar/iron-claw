{
  "meta": {
    "id": "openai-all",
    "name": "OpenAI Full Catalog",
    "description": "Comprehensive catalog for runtime model swapping.",
    "cost_tier": "MIXED",
    "requires_api_key": true,
    "env_var": "OPENAI_API_KEY",
    "env_label": "OpenAI API Key"
  },
  "providers": {
    "openai": {
      "baseUrl": "https://api.openai.com/v1",
      "apiKey": "${OPENAI_API_KEY}",
      "models": [
        { "id": "gpt-5.2", "name": "GPT-5.2 (Ultra)", "tier": "flagship", "cost": { "input": 1.75, "output": 14.0, "cacheRead": 0.175 } },
        { "id": "gpt-5.1", "name": "GPT-5.1 (High)", "tier": "flagship", "cost": { "input": 1.25, "output": 10.0, "cacheRead": 0.125 } },
        { "id": "gpt-5", "name": "GPT-5 (Standard)", "tier": "flagship", "cost": { "input": 1.25, "output": 10.0, "cacheRead": 0.125 } },
        { "id": "gpt-5-mini", "name": "GPT-5 Mini (Sweet Spot)", "tier": "worker", "cost": { "input": 0.25, "output": 2.0, "cacheRead": 0.025 } },
        { "id": "gpt-5-nano", "name": "GPT-5 Nano (Efficiency)", "tier": "efficiency", "cost": { "input": 0.05, "output": 0.4, "cacheRead": 0.005 } },
        { "id": "gpt-4.1", "name": "GPT-4.1", "tier": "flagship", "cost": { "input": 2.0, "output": 8.0, "cacheRead": 0.5 } },
        { "id": "gpt-4.1-mini", "name": "GPT-4.1 Mini", "tier": "worker", "cost": { "input": 0.4, "output": 1.6, "cacheRead": 0.1 } },
        { "id": "gpt-4.1-nano", "name": "GPT-4.1 Nano", "tier": "efficiency", "cost": { "input": 0.1, "output": 0.4, "cacheRead": 0.025 } },
        { "id": "gpt-4o", "name": "GPT-4o", "tier": "legacy-flagship", "cost": { "input": 2.5, "output": 10.0, "cacheRead": 1.25 } },
        { "id": "gpt-4o-mini", "name": "GPT-4o Mini", "tier": "legacy-efficiency", "cost": { "input": 0.15, "output": 0.6, "cacheRead": 0.075 } },
        { "id": "o1", "name": "o1 (Reasoning)", "tier": "reasoning", "cost": { "input": 15.0, "output": 60.0, "cacheRead": 7.5 } },
        { "id": "o3", "name": "o3 (Reasoning High)", "tier": "reasoning", "cost": { "input": 2.0, "output": 8.0, "cacheRead": 0.5 } },
        { "id": "o4-mini", "name": "o4 Mini (Reasoning mini)", "tier": "reasoning", "cost": { "input": 1.1, "output": 4.4, "cacheRead": 0.275 } },
        { "id": "gpt-5-codex", "name": "GPT-5 Codex", "tier": "coding", "cost": { "input": 1.25, "output": 10.0, "cacheRead": 0.125 } },
        { "id": "gpt-5.1-codex-mini", "name": "GPT-5.1 Codex Mini", "tier": "coding", "cost": { "input": 0.25, "output": 2.0, "cacheRead": 0.025 } }
      ]
    }
  },
  "tiers": {
    "flagship": "gpt-5.1",
    "worker": "gpt-5-mini",
    "efficiency": "gpt-5-nano",
    "reasoning": "o3",
    "coding": "gpt-5-codex"
  },
  "agent_defaults": {
    "primary": "openai/gpt-5-mini",
    "fallbacks": ["openai/gpt-4o-mini", "ollama/qwen3:8b"],
    "heartbeat_model": "openai/gpt-5-nano",
    "report_model": "openai/gpt-5-nano"
  }
}
