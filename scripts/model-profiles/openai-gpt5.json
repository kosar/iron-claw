{
  "meta": {
    "id": "openai-gpt5",
    "name": "OpenAI GPT-5-mini",
    "description": "Best for tool-heavy bots. Prompt injection resistant.",
    "cost_tier": "$$",
    "requires_api_key": true,
    "env_var": "OPENAI_API_KEY",
    "env_label": "OpenAI API Key",
    "env_hint": "Get one at https://platform.openai.com/api-keys"
  },
  "providers": {
    "openai": {
      "baseUrl": "https://api.openai.com/v1",
      "apiKey": "${OPENAI_API_KEY}",
      "models": [
        {
          "id": "gpt-5-mini",
          "name": "GPT-5 Mini",
          "reasoning": true,
          "input": ["text"],
          "cost": { "input": 0.25, "output": 2.0, "cacheRead": 0.025, "cacheWrite": 0.25 },
          "contextWindow": 400000,
          "maxTokens": 128000
        },
        {
          "id": "gpt-5-nano",
          "name": "GPT-5 Nano",
          "reasoning": false,
          "input": ["text"],
          "cost": { "input": 0.05, "output": 0.4, "cacheRead": 0.005, "cacheWrite": 0.05 },
          "contextWindow": 400000,
          "maxTokens": 128000
        },
        {
          "id": "gpt-4o",
          "name": "Cloud Fallback",
          "reasoning": false,
          "input": ["text"],
          "cost": { "input": 2.5, "output": 10, "cacheRead": 1.25, "cacheWrite": 2.5 },
          "contextWindow": 200000,
          "maxTokens": 8192
        }
      ]
    }
  },
  "auth_profile": {
    "key": "openai:default",
    "profile": {
      "provider": "openai",
      "mode": "api_key",
      "apiKey": "${OPENAI_API_KEY}",
      "api_key": "${OPENAI_API_KEY}"
    },
    "order_key": "openai",
    "order_value": ["openai:default"]
  },
  "agent_defaults": {
    "primary": "openai/gpt-5-mini",
    "fallbacks": ["openai/gpt-4o", "ollama/qwen3:8b"],
    "heartbeat_model": "openai/gpt-5-nano"
  },
  "identity_model_line": "GPT-5-mini (OpenAI), fallback: Qwen3 8B (local Ollama)",
  "image_gen": {
    "provider_endpoint": "https://api.openai.com/v1/images/generations",
    "provider_env_var": "OPENAI_API_KEY"
  }
}
